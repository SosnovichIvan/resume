# ── Shared secret (must match in both frontend and backend) ──────────────────
SHARED_SECRET=your-32-char-secret-here

# ── Telegram bridge (optional — leave empty to return direct t.me link) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# ── Frontend → backend URL (inside Docker network) ─────────────────────────
NEXT_PUBLIC_API_URL=http://backend:8080
NEXT_PUBLIC_SHARED_SECRET=${SHARED_SECRET}
